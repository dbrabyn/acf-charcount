#. Plugin Name of the plugin
#: acf-charcount.php
#: includes/class-settings.php:97
msgid "ACF Character Count"
msgstr "ACF Compteur de caractères"

#. Plugin URI of the plugin
#: acf-charcount.php
msgid "https://github.com/9wdigital/acf-charcount"
msgstr "https://github.com/9wdigital/acf-charcount"

#. Description of the plugin
#: acf-charcount.php
msgid "Adds live character counters to ACF text-based fields in the WordPress admin UI."
msgstr "Ajoute des compteurs de caractères en temps réel aux champs texte ACF dans l'interface d'administration WordPress."

#. Author of the plugin
#: acf-charcount.php
msgid "9W Digital"
msgstr "9W Digital"

#. Author URI of the plugin
#: acf-charcount.php
msgid "https://9wdigital.com/"
msgstr "https://9wdigital.com/"

#. translators: %s: Advanced Custom Fields plugin name
#: acf-charcount.php:68
#, php-format
msgid "%s requires Advanced Custom Fields (ACF) to be installed and activated."
msgstr "%s nécessite que Advanced Custom Fields (ACF) soit installé et activé."

#: acf-charcount.php:151
#: includes/class-counter.php:91
msgid "characters"
msgstr "caractères"

#: includes/class-settings.php:98
msgid "ACF Char Count"
msgstr "ACF Compteur car."

#: includes/class-settings.php:124
msgid "Default Character Limits"
msgstr "Limites de caractères par défaut"

#: includes/class-settings.php:131
msgid "Text Fields"
msgstr "Champs texte"

#: includes/class-settings.php:137
msgid "Default max characters for text fields. 0 = no limit."
msgstr "Nombre maximum de caractères par défaut pour les champs texte. 0 = pas de limite."

#: includes/class-settings.php:143
msgid "Textarea Fields"
msgstr "Champs zone de texte"

#: includes/class-settings.php:149
msgid "Default max characters for textarea fields. 0 = no limit."
msgstr "Nombre maximum de caractères par défaut pour les champs zone de texte. 0 = pas de limite."

#: includes/class-settings.php:155
msgid "WYSIWYG Fields"
msgstr "Champs WYSIWYG"

#: includes/class-settings.php:161
msgid "Default max characters for WYSIWYG fields. 0 = no limit."
msgstr "Nombre maximum de caractères par défaut pour les champs WYSIWYG. 0 = pas de limite."

#: includes/class-settings.php:168
msgid "Display Settings"
msgstr "Paramètres d'affichage"

#: includes/class-settings.php:175
msgid "Counter Display"
msgstr "Affichage du compteur"

#: includes/class-settings.php:183
msgid "Counter Position"
msgstr "Position du compteur"

#: includes/class-settings.php:222
msgid "Set default maximum character lengths per field type. These apply when no per-field limit is configured via ACF maxlength or [maxchars:N]. Set to 0 for no limit."
msgstr "Définissez le nombre maximum de caractères par défaut pour chaque type de champ. Ces valeurs s'appliquent lorsqu'aucune limite n'est configurée via le maxlength ACF ou [maxchars:N]. Mettez 0 pour aucune limite."

#: includes/class-settings.php:231
msgid "Configure how character counters are displayed on ACF fields."
msgstr "Configurez l'affichage des compteurs de caractères sur les champs ACF."

#: includes/class-settings.php:270
msgid "Always show counter on all supported fields"
msgstr "Toujours afficher le compteur sur tous les champs pris en charge"

#: includes/class-settings.php:275
msgid "Only show on fields with a character limit set (via ACF maxlength, [maxchars:N], or defaults above)"
msgstr "Afficher uniquement sur les champs avec une limite de caractères définie (via maxlength ACF, [maxchars:N] ou les valeurs par défaut ci-dessus)"

#: includes/class-settings.php:292
msgid "Below the field, right-aligned"
msgstr "Sous le champ, aligné à droite"

#: includes/class-settings.php:297
msgid "Below the field, left-aligned"
msgstr "Sous le champ, aligné à gauche"

#: includes/class-settings.php:314
msgid "ACF Character Count Settings"
msgstr "Réglages ACF Compteur de caractères"
